# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/smart_inventory_forecasting

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here

# Frontend URL
FRONTEND_URL=http://localhost:5173

# For Production (Vercel):
# FRONTEND_URL=https://your-frontend.vercel.app

# OpenRouter API (for AI features)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Company Information
COMPANY_NAME=Inventra - Smart Inventory Management Platform
COMPANY_EMAIL=your_company_email@example.com
COMPANY_PHONE=+91-9409297083
COMPANY_ADDRESS=Your Address Here

# Email Settings
SEND_EMAILS=true
ADMIN_EMAIL=admin@example.com
