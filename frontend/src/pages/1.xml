<mxfile host="app.diagrams.net">
  <diagram name="Flowchart">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

    <!-- Start -->
    <mxCell id="start" value="Start" style="ellipse;" vertex="1" parent="1">
      <mxGeometry x="400" y="20" width="100" height="50" as="geometry"/>
    </mxCell>

    <!-- Login -->
    <mxCell id="login" value="User Login" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="100" width="140" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="validate" value="Validate Credentials" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="350" y="180" width="200" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="decision1" value="Valid?" style="rhombus;" vertex="1" parent="1">
      <mxGeometry x="400" y="260" width="100" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="error" value="Show Error" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="260" width="140" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="dashboard" value="Dashboard" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="380" y="360" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- Sales -->
    <mxCell id="sales" value="Create Sales Order" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="50" y="480" width="180" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="stockcheck" value="Stock Available?" style="rhombus;" vertex="1" parent="1">
      <mxGeometry x="70" y="550" width="140" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="processsale" value="Process Sale  Update Inventory" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="640" width="220" height="50" as="geometry"/>
    </mxCell>

    <!-- Purchase -->
    <mxCell id="purchase" value="Create Purchase Order" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="480" width="200" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="receive" value="Receive Items  Update Stock" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="300" y="560" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- Inventory -->
    <mxCell id="inventory" value="Check Stock Levels" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="480" width="200" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="lowstock" value="Low Stock?" style="rhombus;" vertex="1" parent="1">
      <mxGeometry x="610" y="550" width="140" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="alert" value="Generate Alert" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="600" y="640" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- Payment -->
    <mxCell id="payment" value="Process Payment" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="900" y="480" width="180" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="paystatus" value="Success?" style="rhombus;" vertex="1" parent="1">
      <mxGeometry x="930" y="550" width="120" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="updatepay" value="Update Payment Records" style="rounded=1;" vertex="1" parent="1">
      <mxGeometry x="900" y="640" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- End -->
    <mxCell id="end" value="End" style="ellipse;" vertex="1" parent="1">
      <mxGeometry x="450" y="750" width="100" height="50" as="geometry"/>
    </mxCell>

    <!-- Edges -->
    <mxCell edge="1" parent="1" source="start" target="login"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="login" target="validate"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="validate" target="decision1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="decision1" target="dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="decision1" target="error"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="dashboard" target="sales"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="dashboard" target="purchase"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="dashboard" target="inventory"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="dashboard" target="payment"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="sales" target="stockcheck"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="stockcheck" target="processsale"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="purchase" target="receive"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="inventory" target="lowstock"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="lowstock" target="alert"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="payment" target="paystatus"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="paystatus" target="updatepay"><mxGeometry relative="1" as="geometry"/></mxCell>

    <mxCell edge="1" parent="1" source="processsale" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="receive" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="alert" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell edge="1" parent="1" source="updatepay" target="end"><mxGeometry relative="1" as="geometry"/></mxCell>

  </root>
</mxGraphModel>
  </diagram>
</mxfile>
