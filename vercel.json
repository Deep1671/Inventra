{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "nodeVersion": "24.x",
  "env": {
    "VITE_API_BASE_URL": "@vite-api-url"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://inventra-backend.vercel.app/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "^(?!.*\\.).*$",
      "dest": "/index.html"
    }
  ]
}
