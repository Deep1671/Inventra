
{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "https://inventra-1-b17g.onrender.com"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://inventra-backend.vercel.app/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "^(?!.*\\.).*$",
      "dest": "/index.html"
    }
  ]
}
